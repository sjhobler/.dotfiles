# ~/.config/zathura/zathurarc

# ============ Display Settings ============

# Optimal for papers (usually single column)
set pages-per-row 1
set first-page-column 1:1

# Window title shows filename
set window-title-basename true
set window-title-page true

# Selection behavior
set selection-clipboard clipboard
set selection-notification false

# Start in fullscreen mode
set window-height 1024
set window-width 1024

# ============ Color Scheme (Academic Dark) ============

# Main window
set default-fg              "#DDDDDD"
set default-bg              "#1E1E1E"

# Inputbar
set inputbar-fg             "#DDDDDD"
set inputbar-bg             "#2A2A2A"

# Notifications
set notification-fg         "#90A959"
set notification-bg         "#2A2A2A"
set notification-error-fg   "#AC4142"
set notification-error-bg   "#2A2A2A"
set notification-warning-fg "#F4BF75"
set notification-warning-bg "#2A2A2A"

# Statusbar
set statusbar-fg            "#B0B0B0"
set statusbar-bg            "#2A2A2A"

# Highlighting
set highlight-color         "#F4BF75"
set highlight-active-color  "#6A9FB5"
set highlight-transparency  0.4

# Completion menu
set completion-fg           "#DDDDDD"
set completion-bg           "#2A2A2A"
set completion-group-fg     "#6A9FB5"
set completion-group-bg     "#2A2A2A"
set completion-highlight-fg "#1E1E1E"
set completion-highlight-bg "#90A959"

# Recolor mode (dark mode)
set recolor-lightcolor      "#1E1E1E"
set recolor-darkcolor       "#E8E8E8"
set recolor-keephue         false
set recolor-reverse-video   false

# Index mode
set index-fg                "#DDDDDD"
set index-bg                "#1E1E1E"
set index-active-fg         "#1E1E1E"
set index-active-bg         "#90A959"

# ============ Behavior ============

# Search
set incremental-search true
set abort-clear-search true
set search-hadjust true

# Zoom and fit
set zoom-min 10
set zoom-max 1000
set zoom-step 20
set adjust-open "best-fit"

# Performance
set render-loading true
set render-loading-bg "#1E1E1E"
set render-loading-fg "#DDDDDD"

# Database (remembers per-file settings)
set database sqlite

# ============ Index Mode Settings ============

# Index colors (for TOC)
set index-fg "#DDDDDD"
set index-bg "#1E1E1E"
set index-active-fg "#1E1E1E" 
set index-active-bg "#6A9FB5"

# ============ Enable Features ============

# Enable D-Bus (for forward/backward search)
set dbus-service true

# Keep zoom level when following links
set zoom-center false
set vertical-center true

# Show scrollbars
set show-scrollbars false
set show-h-scrollbar false
set show-v-scrollbar false

# Guioptions
set guioptions "sv"

# Use Ctr+click in the PDF to jump to the LaTeX source in nvim. 
set synctex true
set synctex-editor-command "nvim --remote-silent +%{line} %{input}"

# ============ File Type Specific ============

# Two-page view for books (not papers)
# map <C-2> set pages-per-row 2

# ============ External Commands ============

# Open in external viewer
map <C-e> exec "evince '$FILE'"

# Open notes file (markdown with same name)
map <C-n> exec "xdg-open '${FILE%.pdf}.md'"

# Search selection in scholar
map s exec "firefox 'https://scholar.google.com/scholar?q=$SELECTION'"
